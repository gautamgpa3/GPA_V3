[Unit]
Description=GPA V3 FastAPI service
After=network.target

[Service]
User=gpa
Group=gpa
WorkingDirectory=/opt/gpa-v3/app
EnvironmentFile=/opt/gpa-v3/app/.env
ExecStart=/opt/gpa-v3/venv/bin/python -m uvicorn backend.main:app --host ${GPA_HOST} --port ${GPA_PORT}
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
